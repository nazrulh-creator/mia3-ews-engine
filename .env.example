# MIA3 Early Warning Engine — environment configuration
# Copy to .env and adjust. Never commit a real .env.

# Environment ringfence: TEST (amber, watermarked) or LIVE (green).
# Defaults to TEST. LIVE must be set deliberately.
MIA3_ENV=TEST

# Database. Local default is sqlite (zero install). Production uses Postgres:
#   MIA3_DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/mia3
MIA3_DATABASE_URL=sqlite:///./data/runtime/mia3_test.db

# Session signing secret (change in any real deployment).
MIA3_SECRET_KEY=dev-only-change-me

# Path to the trained model artifact. If unset or missing, a synthetic
# stand-in model is trained and used (clearly flagged in the UI).
MIA3_MODEL_PATH=

# Optional Claude-written case-report narrative. OFF by default and
# force-disabled on LIVE so no borrower data leaves the engine.
MIA3_ENABLE_LLM_NARRATIVE=false
